{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Compile",
      "type": "shell",
      "command": "javac",
      "args": ["-d", "build", "-sourcepath", "src/main", "src/main/*.java", "src/main/components/*.java"],
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "Copy Resources",
      "type": "shell",
      "command": "xcopy src\\main\\resources\\* build\\src\\main\\resources\\ /E /Y /I",
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "Build Project",
      "dependsOn": ["Compile", "Copy Resources"],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": []
    },
    {
      "label": "Run",
      "type": "shell",
      "command": "java",
      "args": ["-cp", "build", "App"],
      "group": "test",
      "problemMatcher": []
    }
  ]
}
